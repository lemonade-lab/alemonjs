{
  "version": "independent",
  "workspaces": [
    "frontends/*",
    "packages/*",
    "packages-cl/*",
    "packages-ex/*"
  ],
  "$schema": "node_modules/lerna/schemas/lerna-schema.json",
  "command": {
    "publish": {
      "conventionalCommits": false,
      "allowBranch": "*",
      "message": "chore(release): publish",
      "registry": "https://registry.npmjs.org/"
    }
  }
}