{
  "name": "alemonjs-app",
  "version": "1.0.0",
  "description": "template app",
  "main": "lib/index.js",
  "type": "module",
  "scripts": {
    "app": "node index.js",
    "dev": "npx lvy app.ts",
    "view": "npx lvy app.ts --jsxp",
    "build": "npx lvy build",
    "review": "npx alemonc start",
    "start": "npx pm2 startOrRestart pm2.config.cjs",
    "stop": "npx pm2 stop pm2.config.cjs",
    "delete": "npx pm2 delete pm2.config.cjs"
  },
  "exports": {
    ".": "./lib/index.js",
    "./package": "./package.json"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@alemonjs/db": "^0.0.13",
    "@alemonjs/bubble": "^2.1.4",
    "@alemonjs/discord": "^2.1.7",
    "@alemonjs/onebot": "^2.1.4",
    "@alemonjs/qq-bot": "^2.1.4",
    "alemonjs": "2.1.38",
    "jsxp": "1.2.4",
    "tailwindcss": "3",
    "cssnano": "^7",
    "lvyjs": "^0.3.0-alpha.2",
    "pm2": "^5"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
