{
  "name": "alemonb",
  "version": "1.0.0",
  "description": "阿柠檬机器人",
  "author": "ningmengchongshui",
  "type": "module",
  "main": "lib/index.js",
  "private": true,
  "scripts": {
    "app": "npm run css && npx tsx index.ts",
    "dev": "npm run css && npx tsx  watch --clear-screen=false index.ts",
    "dev-app": "npx tsx routes.server.ts",
    "dev-img": "npx tsx watch --clear-screen=false routes.server.ts",
    "css": "tailwindcss -i ./src/input.css -o ./public/output.css",
    "css-m": "tailwindcss -i ./src/input.css -o ./public/output.css -m",
    "css-dev": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "start": "pm2 startOrRestart pm2.config.cjs",
    "build": "rollup --config rollup.config.js",
    "stop": "pm2 stop pm2.config.cjs",
    "delete": "pm2 delete pm2.config.cjs",
    "kill": "pm2 kill",
    "logs": "pm2 logs",
    "monit": "pm2 monit",
    "pm2": "pm2",
    "format": "prettier --write .",
    "check-format": "git diff --exit-code",
    "prepare": "husky"
  },
  "dependencies": {
    "@alemonjs/kook": "^0.0.2",
    "@alemonjs/qq": "^0.0.3",
    "alemonjs": "^2.0.0-rc.6",
    "ioredis": "^5.3.2",
    "lodash": "^4.17.21",
    "mysql2": "^3.5.2",
    "react": "^18.3.1",
    "react-puppeteer": "^1.0.7",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/inquirer": "^9.0.7",
    "@types/lodash": "^4.17.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.8.5",
    "@types/node-localstorage": "^1.3.3",
    "@types/node-schedule": "^2.1.2",
    "@types/react": "^18.3.8",
    "@types/redis": "^4.0.11",
    "autoprefixer": "^10.4.20",
    "husky": "^9.0.11",
    "image-size": "^1.1.1",
    "pm2": "^5.4.2",
    "postcss": "^8.4.47",
    "prettier": "^2.8.8",
    "rollup": "^4.18.1",
    "rollup-plugin-dts": "^6.1.1",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=16.14.0"
  }
}
