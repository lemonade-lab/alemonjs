{
  "name": "alemonb",
  "version": "1.0.0",
  "description": "阿柠檬机器人",
  "author": "ningmengchongshui",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "alemonjs dev --login kook",
    "dev-qq": "alemonjs dev --login qq",
    "build": "alemonjs build",
    "review": "alemonjs start --input ./lib/src/index.js",
    "img-dev": "concurrently 'npm run css-dev' 'tsxp dev' ",
    "css": "tailwindcss -i ./src/input.css -o ./public/output.css",
    "css-m": "tailwindcss -i ./src/input.css -o ./public/output.css -m",
    "css-dev": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "start": "pm2 startOrRestart pm2.config.cjs",
    "stop": "pm2 stop pm2.config.cjs",
    "delete": "pm2 delete pm2.config.cjs",
    "format": "prettier --write .",
    "check-format": "git diff --exit-code",
    "prepare": "husky"
  },
  "dependencies": {
    "@alemonjs/kook": "^0.0.2",
    "@alemonjs/qq": "^0.0.3",
    "alemonjs": "^2.0.0-rc.15",
    "image-size": "^1.1.1",
    "ioredis": "^5.3.2",
    "lodash-es": "^4.17.21",
    "mysql2": "^3.5.2",
    "react-puppeteer": "^1.1.0",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.8.5",
    "@types/node-schedule": "^2.1.2",
    "@types/react": "^18.3.8",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "husky": "^9.0.11",
    "pm2": "^5.4.2",
    "postcss": "^8.4.47",
    "prettier": "^2.8.8",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3"
  },
  "engines": {
    "node": ">=16.14.0"
  }
}
