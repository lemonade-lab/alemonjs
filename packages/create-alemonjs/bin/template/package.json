{
  "name": "alemonb",
  "version": "1.0.0",
  "description": "阿柠檬机器人",
  "author": "ningmengchongshui",
  "type": "module",
  "main": "lib/index.js",
  "private": true,
  "scripts": {
    "dev": "npm run css && alemonjs dev --input ./src/index.ts --login kook",
    "dev-qq": "npm run css && alemonjs dev --input ./src/index.ts --login qq",
    "build": "npm run css && alemonjs build --input ./src/index.ts --output ./lib",
    "img-dev": "tsxp dev",
    "css": "tailwindcss -i ./src/input.css -o ./public/output.css",
    "css-m": "tailwindcss -i ./src/input.css -o ./public/output.css -m",
    "css-dev": "tailwindcss -i ./src/input.css -o ./public/output.css --watch",
    "start": "pm2 startOrRestart pm2.config.cjs",
    "stop": "pm2 stop pm2.config.cjs",
    "delete": "pm2 delete pm2.config.cjs"
  },
  "dependencies": {
    "@alemonjs/kook": "^0.0.2",
    "@alemonjs/qq": "^0.0.3",
    "alemonjs": "^2.0.0-rc.11",
    "image-size": "^1.1.1",
    "ioredis": "^5.3.2",
    "lodash-es": "^4.17.21",
    "mysql2": "^3.5.2",
    "react-puppeteer": "^1.1.0",
    "sequelize": "^6.32.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.8.5",
    "@types/node-schedule": "^2.1.2",
    "pm2": "^5.4.2",
    "tailwindcss": "^3.4.13"
  },
  "engines": {
    "node": ">=16.14.0"
  }
}
