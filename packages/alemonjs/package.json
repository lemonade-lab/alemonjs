{
  "name": "alemonjs",
  "version": "2.0.0-rc.14",
  "description": "啊柠檬脚本",
  "author": "ningmengchongshui",
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "dependencies": {
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-alias": "^5.1.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-typescript": "^11.1.6",
    "axios": "^1.4.0",
    "chokidar": "^4.0.1",
    "rollup": "^4.18.1",
    "rollup-plugin-dts": "^6.1.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.3",
    "yaml": "^2.5.1"
  },
  "types": "lib",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    },
    "./loader": {
      "import": "./lib/loader/index.js",
      "types": "./lib/loader/index.d.ts"
    },
    "./register": {
      "import": "./lib/main.js"
    },
    "./env": {
      "types": "./env.d.ts"
    },
    "./plugins": {
      "import": "./lib/plugins/index.js",
      "types": "./lib/plugins/index.d.ts"
    },
    "./tsconfig.json": {
      "import": "./tsconfig.json",
      "require": "./tsconfig.json",
      "types": "./tsconfig.json"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=16.14.0"
  },
  "bugs": "https://github.com/ningmengchongshui/alemonjs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/ningmengchongshui/alemonjs.git"
  },
  "bin": {
    "alemonjs": "bin/index.js"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
