{
  "name": "alemonjs",
  "version": "2.2.0-rc.0",
  "description": "bot script",
  "author": "lemonade",
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "scripts": {
    "build": "lvy build"
  },
  "types": "lib",
  "exports": {
    "./package": "./package.json",
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts",
      "require": "./dist/index.js"
    },
    "./utils": {
      "import": "./lib/utils.js",
      "types": "./lib/utils.d.ts",
      "require": "./lib/utils.js"
    },
    "./env": {
      "types": "./lib/global.d.ts"
    }
  },
  "dependencies": {
    "axios": "^1.10.0",
    "chalk": "^5.3.0",
    "commander": "^13.1.0",
    "file-type": "21.0.0",
    "flatted": "^3.3.3",
    "log4js": "^6.9.1",
    "public-ip": "^7.0.1",
    "qrcode": "^1.5.4",
    "uuid": "11.1.0",
    "ws": "^8.18.0",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0"
  },
  "bin": {
    "alemonc": "./bin/alemonc.js"
  },
  "keywords": [
    "alemonjs"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "bugs": "https://github.com/lemonade-lab/alemonjs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/lemonade-lab/alemonjs.git"
  }
}
